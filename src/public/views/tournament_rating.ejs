<div class="container">
    <div class="row"><i class="toggler bi bi-chevron-down" onclick="toggler.toggle(this)"></i></div>
    <div id="player" class="player closable">
        <div class="container">
            <% if (user) { %>
                <h1 class="text-center no-selection">Игроки</h1>
            <% } %>
            <div class="col-lg-12 col-md-12 col-sm-12 desc">
                <table id="player-table" data-editable="true"></table>
            </div>
        </div>
    </div>
    <hr class="hr-dashed"/>
</div>

<div id="player-window" class="modal fade" tabindex="-1"></div>

<div id="player-signup-window" class="modal fade" tabindex="-1">
    <%- include('signup', { kind: 'modal', states: states, regions: regions, cities: cities } ); %>
</div>

<% if (user) { %>
    <div class="select" id="select">
        <div class="container">
            <h1 class="text-center no-selection">Подбор</h1>
            <div id="select-block" class="col-lg-12 col-md-12 col-sm-12 desc">
                <div id="select-info" class="row" style="display:none">
                    <div class="text-center no-selection">
                        <label>Нет игроков, подходящих под критерии выбора: зарегистрируйте больше игроков на </label>
                        <a onclick="scrollToId('player')" href="#">турнир</a>
                        <label>или добавьте </label>
                        <a onclick="scrollToId('court')" href="#">корты</a>
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    </div>
                </div>
                <div class="row">
                    <div class="text-center">
                        <button id="select-button" type="button" class="btn btn-lg btn-success mx-auto w-auto">Подобрать</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="game" id="game">
        <div class="container">
            <h1 class="text-center no-selection">Игры</h1>
            <div class="game-info row">
                <div class="text-center no-selection">
                    <label>Тут появится информация по играм, после их </label>
                    <a onclick="scrollToId('select')" href="#">подбора</a>
                </div>
            </div>
            <div id="game-block"></div>
        </div>
    </div>
<% } %>

<div class="container">
    <div class="row"><i class="toggler bi bi-chevron-down" onclick="toggler.toggle(this)"></i></div>
    <div id="match-history" class="match-history closable">
        <% if (user) { %>
            <h1 class="text-center no-selection">История матчей</h1>
        <% } %>
        <div class="col-lg-12 col-md-12 col-sm-12 desc">
            <div id="match-history-block" class="row justify-content-center mx-auto">
                <% matches.forEach((m, i) => { %>
                    <%- include('match', {index: i, match: m}); %>
                <% }) %>
            </div>
        </div>
    </div>
    <hr class="hr-dashed"/>
</div>

<% if (user) { %>
    <div class="container">
        <div class="row"><i class="toggler bi bi-chevron-down" onclick="toggler.toggle(this)"></i></div>
        <div id="cort" class="cort closable">
            <h1 class="text-center no-selection">Корты</h1>
            <table id="cort-table" class="mx-auto w-auto"></table>
        </div>
        <hr class="hr-dashed"/>
    </div>

    <div class="container">
        <div class="row"><i class="toggler bi bi-chevron-down" onclick="toggler.toggle(this)"></i></div>
        <div id="tournament" class="tournament closable">
            <h1 class="text-center no-selection">Турнир</h1>
            <table id="tournament-table" class="mx-auto w-auto"></table>
            <div class="row">
                <div class="text-center">
                    <button id="tournament-add" type="button" class="btn btn-lg btn-success mx-auto w-auto m-3">Добавить</button>
                </div>
            </div>
        </div>
        <hr class="hr-dashed"/>
    </div>

    <div class="container">
        <div class="row"><i class="toggler bi bi-chevron-down" onclick="toggler.toggle(this)"></i></div>
        <div id="settings" class="settings closable">
            <h1 class="text-center no-selection">Настройки</h1>
            <table id="settings-table" class="mx-auto w-auto"></table>
        </div>
        <hr class="hr-dashed"/>
    </div>

    <div class="container">
        <div class="row"><i class="toggler bi bi-chevron-down" onclick="toggler.toggle(this)"></i></div>
        <div id="player-archive" class="player-archive closable">
            <h1 class="text-center no-selection">Архив</h1>
            <table id="player-archive-table" class="justify-content-center mx-auto w-auto"></table>
        </div>
        <hr class="hr-dashed"/>
    </div>
<% } %>
<% if (device === 'phone') { %>
    <div class="col text-center">
        <div class="social no-selection">
            <%- include('social', {device: device}); %>
        </div>
    </div>
<% } %>